rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - description: string (required)
    //   - opinion: string (required)
    //   - price: string (required)
    //   - image: string (required, URL)
    //   - amazonUrl: string (required, Amazon URL with tag)
    //   - rating: number (1-5)
    //   - createdAt: timestamp (server-generated)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.email == "thaisalima.ofertas@gmail.com";
    }

    // Domain Validators
    function isValidProduct(data) {
      return data.keys().hasAll(['title', 'description', 'opinion', 'price', 'image', 'amazonUrl', 'rating', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 1000 &&
             data.opinion is string && data.opinion.size() > 0 && data.opinion.size() < 1000 &&
             data.price is string && data.price.size() > 0 && data.price.size() < 50 &&
             data.image is string && data.image.matches("^https?://.*") &&
             data.amazonUrl is string && data.amazonUrl.matches("^https?://.*amazon\\.com\\.br.*") &&
             data.rating is number && data.rating >= 1 && data.rating <= 5;
    }

    match /products/{productId} {
      // Products are publicly readable for the catalog
      allow read: if true;
      
      // Only admin can create or modify products
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /test/{docId} {
      allow read, write: if isAuthenticated();
    }
  }
}
